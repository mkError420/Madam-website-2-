rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tracks
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - album: string (required)
    //   - duration: string (required)
    //   - year: string (required)
    //   - cover: string (required)
    //   - audioUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: videos
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - thumbnail: string (required)
    //   - duration: string (required)
    //   - views: string (required)
    //   - category: string (required)
    //   - description: string (optional)
    //   - videoUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - price: number (required)
    //   - image: string (required)
    //   - category: string (required)
    //   - isNew: bool (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //   - displayName: string (optional)
    //
    // Collection: gallery
    // Document ID: auto-generated
    // Fields:
    //   - url: string (required)
    //   - caption: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "mk.rabbani.cse@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidTrack(data) {
      return hasRequiredFields(['title', 'album', 'duration', 'year', 'cover', 'createdAt']) &&
             data.title is string && data.title.size() > 0 &&
             data.album is string && data.album.size() > 0 &&
             data.duration is string &&
             data.year is string &&
             isValidUrl(data.cover) &&
             data.createdAt is timestamp;
    }

    function isValidVideo(data) {
      return hasRequiredFields(['title', 'thumbnail', 'duration', 'views', 'category', 'createdAt']) &&
             data.title is string && data.title.size() > 0 &&
             isValidUrl(data.thumbnail) &&
             data.duration is string &&
             data.views is string &&
             data.category is string &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'image', 'category', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is number && data.price >= 0 &&
             isValidUrl(data.image) &&
             data.category is string &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidGalleryImage(data) {
      return hasRequiredFields(['url', 'createdAt']) &&
             isValidUrl(data.url) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tracks/{trackId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidTrack(request.resource.data);
      allow update: if isAdmin() && isValidTrack(request.resource.data);
      allow delete: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidVideo(request.resource.data);
      allow update: if isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidGalleryImage(request.resource.data);
      allow update: if isAdmin() && isValidGalleryImage(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
